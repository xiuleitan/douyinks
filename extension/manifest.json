{
  "manifest_version": 3,
  "name": "Douyinks Browser Bridge",
  "version": "1.0.0",
  "description": "Browser automation bridge for Douyinks.",
  "permissions": [
    "debugger",
    "tabs",
    "cookies",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Douyinks",
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
